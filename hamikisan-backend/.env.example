PORT=5000

# Security
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=*

# PostgreSQL (use either DATABASE_URL or individual DB_* vars)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/hamikisan_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hamikisan_db

# Redis
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
